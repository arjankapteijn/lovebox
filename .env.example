# Kopieer naar .env en vul in. .env staat in .gitignore — commit hem nooit.
# LET OP: verjaardagen/activiteiten bevatten persoonsgegevens (namen, datums).
# Houd die dus in .env / de container-omgeving, niet in de publieke repo.

# ── Lovebox account + doelbox (verplicht) ────────────────────────────────
LOVEBOX_EMAIL=jouw@email.nl
LOVEBOX_PASSWORD=jouwWachtwoord
LOVEBOX_BOX_ID=jouwBoxIdHier

# ── Locatie voor de weersverwachting (optioneel) ─────────────────────────
LOVEBOX_LAT=52.3415
LOVEBOX_LON=5.6147
LOVEBOX_LOCATION_NAME=Harderwijk

# ── Verjaardagen (JSON-lijst) ────────────────────────────────────────────
# Verschijnen pas binnen LOVEBOX_BIRTHDAY_WINDOW_DAYS (standaard 30 dagen).
# "date": "YYYY-MM-DD" toont ook de leeftijd; "MM-DD" alleen "jarig".
LOVEBOX_BIRTHDAYS=[{"name":"Emma","date":"2018-03-15"},{"name":"Sem","date":"07-01"}]

# ── Activiteiten (JSON-lijst) ────────────────────────────────────────────
# "date": "YYYY-MM-DD" = eenmalig; "MM-DD" = jaarlijks terugkerend (bv. Sint).
LOVEBOX_EVENTS=[{"name":"Schoolreisje","date":"2026-07-10"},{"name":"Sinterklaas","date":"12-05"}]

# ── Weergave-instellingen (optioneel) ────────────────────────────────────
LOVEBOX_BIRTHDAY_WINDOW_DAYS=30
LOVEBOX_EVENT_WINDOW_DAYS=30
LOVEBOX_MAX_SLOTS=2

# ── Scheduler (self-scheduling container) ────────────────────────────────
# Dagelijks versturen rond dit tijdstip in deze tijdzone.
LOVEBOX_RUN_AT=07:00
LOVEBOX_TZ=Europe/Amsterdam
# Meteen bij (her)start één keer versturen? Handig om een deploy te testen.
LOVEBOX_RUN_ON_START=false
# Eén keer draaien en stoppen i.p.v. de scheduler (bv. voor lokaal testen).
LOVEBOX_RUN_ONCE=false
